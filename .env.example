# ====================== DOMAIN & TIMEZONE ======================
NC_DOMAIN=                                      # TODO! Your Nextcloud domain (e.g. cloud.example.com)
TIMEZONE=                                       # TODO! e.g. America/New_York

# ====================== VLAN / NETWORKING ======================
VLAN_TAG=                                       # TODO! VLAN tag number
VLAN_TRUNK_INTERFACE=                           # TODO! e.g. eth0
DNS_SERVER=                                     # TODO! LAN DNS server IP

# ====================== SECRETS ======================
# WARNING: Do not use @ or : in passwords (breaks database connection strings)
DATABASE_PASSWORD=                              # TODO! Unique strong password
REDIS_PASSWORD=                                 # TODO!
NEXTCLOUD_PASSWORD=                             # TODO! Initial admin password (user: admin)
ONLYOFFICE_SECRET=                              # TODO!
EUROOFFICE_SECRET=placeholder                   # Unused (eurooffice disabled), but referenced by nextcloud container
SIGNALING_SECRET=                               # TODO!
TURN_SECRET=                                    # TODO!
TALK_INTERNAL_SECRET=                           # TODO!
FULLTEXTSEARCH_PASSWORD=                        # TODO!
IMAGINARY_SECRET=                               # TODO!
RECORDING_SECRET=placeholder                    # Unused (talk-recording disabled), but referenced by nextcloud container
WHITEBOARD_SECRET=placeholder                   # Unused (whiteboard disabled), but referenced by nextcloud container

# ====================== FEATURE TOGGLES ======================
COLLABORA_ENABLED="yes"                         # Enabled and fixed by the local compose file
TALK_ENABLED="yes"
CLAMAV_ENABLED="yes"
IMAGINARY_ENABLED="yes"
ONLYOFFICE_ENABLED="no"                         # Service omitted; changing this does not enable it
EUROOFFICE_ENABLED="no"
FULLTEXTSEARCH_ENABLED="yes"
TALK_RECORDING_ENABLED="no"
WHITEBOARD_ENABLED="no"

# ====================== APACHE / REVERSE PROXY ======================
APACHE_IP_BINDING=0.0.0.0                       # Upstream variable; unused by this ipvlan stack
APACHE_PORT=11000
APACHE_MAX_SIZE=17179869184                     # Must be in sync with NEXTCLOUD_UPLOAD_LIMIT (bytes)
AIO_LOG_LEVEL=warn                              # Global AIO log level: debug, info, warn, or error

# ====================== NEXTCLOUD ======================
NEXTCLOUD_DATADIR=/mnt/ncdata                   # WARNING: Do not change after initial install!
NEXTCLOUD_MOUNT=                                # Empty = local external storage disabled. Set to a host path (e.g. /mnt/) if needed.
NEXTCLOUD_UPLOAD_LIMIT=16G
NEXTCLOUD_MAX_TIME=3600
NEXTCLOUD_MEMORY_LIMIT=4096M
NEXTCLOUD_STARTUP_APPS="memories twofactor_totp tasks calendar contacts notes"
NEXTCLOUD_ADDITIONAL_APKS=imagemagick
NEXTCLOUD_ADDITIONAL_PHP_EXTENSIONS=imagick
INSTALL_LATEST_MAJOR=no                                 # Only affects first install — ignored when migrating existing volumes
UPDATE_NEXTCLOUD_APPS="no"
REMOVE_DISABLED_APPS=yes
NEXTCLOUD_TRUSTED_CACERTS_DIR=                   # Empty = skip CA update. Set to a host dir of .crt files if needed.

# ====================== COLLABORA ======================
COLLABORA_DICTIONARIES="en_CA"
ADDITIONAL_COLLABORA_OPTIONS=['--o:security.seccomp=true']

# ====================== TALK ======================
TALK_PORT=3478

# ====================== FULLTEXTSEARCH ======================
FULLTEXTSEARCH_JAVA_OPTIONS="-Xms512M -Xmx512M"
